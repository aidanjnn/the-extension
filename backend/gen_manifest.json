{
  "name": "Yellow",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Changes the background of YouTube to yellow.",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ]
}